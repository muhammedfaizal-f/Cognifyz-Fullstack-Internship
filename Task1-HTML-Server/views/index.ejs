<%- include('partials/header') %>

<!-- Hero -->
<section class="hero fade-up">
  <div class="hero-badge">
    <span class="hero-dot"></span>
    Cognifyz · Level 1 · Task 1
  </div>
  <h1 class="hero-title">HTML Structure &amp;<br /><span class="gradient-text">Server-Side Rendering</span></h1>
  <p class="hero-sub">
    A Node.js + Express server using EJS templates for dynamic HTML generation,
    form handling, and server-side validation — all without a frontend framework.
  </p>
  <div class="hero-actions">
    <a href="/register" class="btn btn-primary">→ Get Started</a>
    <a href="/contact"  class="btn btn-outline">✉ Contact Us</a>
  </div>
</section>

<!-- Stats -->
<section class="stats-row fade-up">
  <div class="stat-card">
    <div class="stat-icon" style="background:rgba(63,185,80,.12);color:#3fb950">📋</div>
    <div class="stat-num"><%= contactCount %></div>
    <div class="stat-label">Contact Submissions</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:rgba(88,166,255,.12);color:#58a6ff">👤</div>
    <div class="stat-num"><%= registerCount %></div>
    <div class="stat-label">Registrations</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:rgba(224,123,57,.12);color:#e07b39">⚡</div>
    <div class="stat-num">EJS</div>
    <div class="stat-label">Template Engine</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:rgba(210,153,34,.12);color:#d29922">🛡️</div>
    <div class="stat-num">SSR</div>
    <div class="stat-label">Server-Side Rendering</div>
  </div>
</section>

<!-- How it works -->
<section class="steps-section fade-up">
  <div class="section-eyebrow">How It Works</div>
  <h2 class="section-title">Server-side flow</h2>
  <div class="steps-grid">
    <div class="step-card">
      <div class="step-num">01</div>
      <h4>HTML Form</h4>
      <p>User fills a form and submits — standard HTML POST request to the Express server.</p>
    </div>
    <div class="step-card">
      <div class="step-num">02</div>
      <h4>Server Validation</h4>
      <p>Express-validator checks every field server-side. Errors are returned with the old input.</p>
    </div>
    <div class="step-card">
      <div class="step-num">03</div>
      <h4>EJS Rendering</h4>
      <p>EJS template receives data from the controller and dynamically generates the HTML response.</p>
    </div>
    <div class="step-card">
      <div class="step-num">04</div>
      <h4>Dynamic Response</h4>
      <p>The browser receives a fully rendered HTML page — no JavaScript framework needed.</p>
    </div>
  </div>
</section>

<!-- Recent submissions -->
<% if (submissions.length > 0) { %>
<section class="submissions-section fade-up">
  <div class="section-eyebrow">Live Data</div>
  <h2 class="section-title">Recent contact submissions</h2>
  <div class="submissions-list">
    <% submissions.forEach(function(s) { %>
    <div class="submission-row">
      <div class="sub-avatar"><%= s.name[0].toUpperCase() %></div>
      <div class="sub-info">
        <div class="sub-name"><%= s.name %></div>
        <div class="sub-email"><%= s.email %></div>
        <div class="sub-subject"><%= s.subject %></div>
      </div>
      <div class="sub-time"><%= s.createdAt %></div>
    </div>
    <% }) %>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="cta-section fade-up">
  <h2 class="cta-title">Try the forms below</h2>
  <p class="cta-sub">Both forms use server-side validation — try submitting empty or invalid data.</p>
  <div class="cta-btns">
    <a href="/register" class="btn btn-primary">→ Register</a>
    <a href="/contact"  class="btn btn-outline">✉ Contact</a>
  </div>
</section>

<%- include('partials/footer') %>